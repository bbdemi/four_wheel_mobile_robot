<?xml version="1.0"?>
<robot name="macroed" xmlns:xacro="http://ros.org/wiki/xacro">

  <xacro:property name="length" value="0.4" />
  <xacro:property name="width" value="0.25" />
  <xacro:property name="height" value="0.6" />
  <xacro:property name="wheellen" value="0.1" />
  <xacro:property name="wheeldia" value="0.07" />

  <material name="blue">
    <color rgba="0 0 0.8 1"/>
  </material>

  <material name="black">
    <color rgba="0 0 0 1"/>
  </material>

  <material name="white">
    <color rgba="1 1 1 1"/>
  </material>

  <material name="blue">
    <color rgba="0 0 0.8 1"/>
  </material>

  <material name="black">
    <color rgba="0 0 0 1"/>
  </material>

  <material name="white">
    <color rgba="1 1 1 1"/>
  </material>
  
   <link name="base_link">
  <visual>
    <geometry>
     <box size="${length} ${width} ${height}"/>
    </geometry>
    <material name="blue"/>
  </visual>
  </link>
  
  <link name="right_front_wheel">
    <visual>
      <origin rpy="1.57075 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="${wheellen}" radius="${wheeldia/2}"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>
  
  <link name="right_back_wheel">
    <visual>
      <origin rpy="1.57075 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="${wheellen}" radius="${wheeldia/2}"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>
  
   <link name="left_front_wheel">
    <visual>
      <origin rpy="1.57075 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="${wheellen}" radius="${wheeldia/2}"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  
   <link name="left_back_wheel">
    <visual>
      <origin rpy="1.57075 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="${wheellen}" radius="${wheeldia/2}"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>
  
  <joint name="base_to_right_front_wheel" type="fixed">
  <parent link="base_link"/>
  <child link="right_front_wheel"/>
  <origin xyz="0.15 -0.17 -0.05" rpy="0 0 0"/>
</joint>

 <joint name="base_to_right_back_wheel" type="fixed">
  <parent link="base_link"/>
  <child link="right_back_wheel"/>
  <origin xyz="0.15 +0.17 -0.05" rpy="0 0 0"/>
</joint>

<joint name="base_to_left_back_wheel" type="fixed">
  <parent link="base_link"/>
  <child link="left_back_wheel"/>
  <origin xyz="-0.15 +0.17 -0.05" rpy="0 0 0"/>
</joint>

<joint name="base_to_left_front_wheel" type="fixed">
  <parent link="base_link"/>
  <child link="left_front_wheel"/>
  <origin xyz="-0.15 -0.17 -0.05" rpy="0 0 0"/>
</joint>

</robot>


<?xml version="1.0"?>
<robot name="mobile_robot">
  
  <link name="base_link">
  <visual>
    <geometry>
      <box size="0.4 0.25 0.08"/>
    </geometry>
    <material name="blue"/>
  </visual>
  </link>


  <material name="blue">
    <color rgba="0 0 0.8 1"/>
  </material>

  <material name="black">
    <color rgba="0 0 0 1"/>
  </material>

  <material name="white">
    <color rgba="1 1 1 1"/>
  </material>
  
  <link name="right_front_wheel">
    <visual>
      <origin rpy="1.57075 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.1" radius="0.035"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>
  
  <link name="right_back_wheel">
    <visual>
      <origin rpy="1.57075 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.1" radius="0.035"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>
  
   <link name="left_front_wheel">
    <visual>
      <origin rpy="1.57075 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.1" radius="0.035"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  
   <link name="left_back_wheel">
    <visual>
      <origin rpy="1.57075 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.1" radius="0.035"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>
  
  <joint name="base_to_right_front_wheel" type="fixed">
  <parent link="base_link"/>
  <child link="right_front_wheel"/>
  <origin xyz="0.15 -0.17 -0.05" rpy="0 0 0"/>
</joint>

 <joint name="base_to_right_back_wheel" type="fixed">
  <parent link="base_link"/>
  <child link="right_back_wheel"/>
  <origin xyz="0.15 +0.17 -0.05" rpy="0 0 0"/>
</joint>

<joint name="base_to_left_back_wheel" type="fixed">
  <parent link="base_link"/>
  <child link="left_back_wheel"/>
  <origin xyz="-0.15 +0.17 -0.05" rpy="0 0 0"/>
</joint>

<joint name="base_to_left_front_wheel" type="fixed">
  <parent link="base_link"/>
  <child link="left_front_wheel"/>
  <origin xyz="-0.15 -0.17 -0.05" rpy="0 0 0"/>
</joint>

</robot>

